// Reimbursement Management System — Prisma Schema
// PostgreSQL + UUID primary keys + full enum types

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ExpenseCategory {
  TRAVEL
  FOOD
  ACCOMMODATION
  EQUIPMENT
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum ConditionalRuleType {
  NONE
  PERCENTAGE
  SPECIFIC_APPROVER
  HYBRID
}

enum OcrJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

// ─── MODELS ──────────────────────────────────────────────

model Company {
  id              String   @id @default(uuid())
  name            String
  country         String
  defaultCurrency String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users              User[]
  expenses           Expense[]
  approvalTemplates  ApprovalTemplate[]
  routingRules       TemplateRoutingRule[]

  @@index([name])
  @@map("companies")
}

model User {
  id                 String   @id @default(uuid())
  companyId          String
  name               String
  email              String   @unique
  passwordHash       String
  role               Role     @default(EMPLOYEE)
  managerId          String?
  isManagerApprover  Boolean  @default(false)
  mustChangePassword Boolean  @default(false)
  refreshToken       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  manager            User?    @relation("ManagerSubordinates", fields: [managerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  subordinates       User[]   @relation("ManagerSubordinates")

  submittedExpenses  Expense[]          @relation("SubmittedExpenses")
  expenseApprovals   ExpenseApproval[]
  approvalSteps      ApprovalStep[]
  passwordResetTokens PasswordResetToken[]

  // Reverse relation for specific approver in templates
  specificApproverTemplates ApprovalTemplate[] @relation("SpecificApprover")

  @@index([companyId])
  @@index([email])
  @@index([managerId])
  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model Expense {
  id               String          @id @default(uuid())
  companyId        String
  submittedById    String
  templateId       String?
  routingRuleId    String?
  amount           Decimal         @db.Decimal(12, 2)
  currency         String
  convertedAmount  Decimal?        @db.Decimal(12, 2)
  companyCurrency  String?
  exchangeRateUsed Decimal?        @db.Decimal(12, 6)
  rateTimestamp    DateTime?
  category         ExpenseCategory
  description      String
  date             DateTime
  status           ExpenseStatus   @default(PENDING)
  receiptUrl       String?
  ocrExtracted     Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relations
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  submittedBy   User                 @relation("SubmittedExpenses", fields: [submittedById], references: [id], onDelete: Cascade, onUpdate: Cascade)
  template      ApprovalTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  routingRule   TemplateRoutingRule? @relation(fields: [routingRuleId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  approvals     ExpenseApproval[]
  ocrJob        OcrJob?

  @@index([submittedById])
  @@index([status])
  @@index([companyId, status])
  @@map("expenses")
}

model ApprovalTemplate {
  id                   String             @id @default(uuid())
  companyId            String
  name                 String
  conditionalRuleType  ConditionalRuleType @default(NONE)
  percentageThreshold  Float?
  specificApproverId   String?
  isDefault            Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Relations
  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  specificApprover  User?                @relation("SpecificApprover", fields: [specificApproverId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  steps             ApprovalStep[]
  expenses          Expense[]
  routingRules      TemplateRoutingRule[]

  @@index([companyId])
  @@map("approval_templates")
}

model TemplateRoutingRule {
  id         String   @id @default(uuid())
  companyId  String
  templateId String
  minAmount  Decimal  @db.Decimal(12, 2)
  maxAmount  Decimal? @db.Decimal(12, 2)  // null = unbounded upper limit
  priority   Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  template ApprovalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  expenses Expense[]

  @@index([companyId, isActive])
  @@index([templateId])
  @@map("template_routing_rules")
}

model ApprovalStep {
  id         String   @id @default(uuid())
  templateId String
  stepOrder  Int
  approverId String
  roleLabel  String?  // e.g., "Manager", "Finance", "Director"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  template ApprovalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  approver User             @relation(fields: [approverId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([templateId, stepOrder])
  @@index([templateId])
  @@map("approval_steps")
}

model ExpenseApproval {
  id         String         @id @default(uuid())
  expenseId  String
  approverId String
  stepOrder  Int
  status     ApprovalStatus @default(PENDING)
  comments   String?
  actionedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  // Relations
  expense  Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  approver User    @relation(fields: [approverId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([expenseId])
  @@index([approverId, status])
  @@map("expense_approvals")
}

model OcrJob {
  id         String       @id @default(uuid())
  expenseId  String       @unique
  status     OcrJobStatus @default(QUEUED)
  rawResponse Json?
  parsedData  Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  // Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([expenseId])
  @@map("ocr_jobs")
}

model ExchangeRate {
  id             String   @id @default(uuid())
  baseCurrency   String
  targetCurrency String
  rate           Decimal  @db.Decimal(12, 6)
  fetchedAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([baseCurrency, targetCurrency])
  @@map("exchange_rates")
}
